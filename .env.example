# =====================================================
# CJ HEALTH SUPPLY — Variables de entorno
# Copia este archivo como .env y rellena los valores
# =====================================================

# Supabase
# Obtener en: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.tu-anon-key

# MercadoPago
# Obtener en: https://www.mercadopago.cl/developers/panel/credentials
# Usar credenciales TEST para desarrollo, PROD para producción
VITE_MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Variables backend (Vercel Functions / Supabase Edge Functions)
# NO usar el prefijo VITE_ — estas NO van al cliente
MP_ACCESS_TOKEN=TEST-1234567890123456-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-123456789

# Webhook HMAC (opcional — genera una clave aleatoria larga)
# Si no se configura, el webhook acepta todos los eventos sin verificar firma
MP_WEBHOOK_SECRET=

# Supabase (usadas sólo por el webhook de MercadoPago en el servidor)
# Obtener en: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.tu-service-role-key
